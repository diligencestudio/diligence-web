# ─── MongoDB (docker-compose) ─────────────────────────────────────────────
MONGO_USER=diligence
MONGO_PASSWORD=diligence
MONGO_DB=diligence
# Puerto del host para el Mongo de docker (27018 evita choque con un Mongo local en 27017)
MONGO_HOST_PORT=27018

# ─── API (apps/api) ───────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
# Conexión a Mongo (usuario/clave del bloque anterior)
MONGODB_URI=mongodb://diligence:diligence@localhost:27018/diligence?authSource=admin
# URL pública del storefront (para redirects de checkout)
WEB_URL=http://localhost:3000
# Orígenes permitidos por CORS (coma-separados)
CORS_ORIGINS=http://localhost:3000

# ─── Wompi (sandbox) ──────────────────────────────────────────────────────
# Consíguelas en el dashboard de Wompi (ambiente de pruebas)
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxx
# URL del Web Checkout de Wompi
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# ─── Admin / Auth ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@diligence.co
ADMIN_PASSWORD=cambia-esta-clave
JWT_SECRET=genera-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=12h

# ─── Cloudinary (subida de imágenes del admin) ──────────────────────────────
# Crea una cuenta gratis en cloudinary.com y copia estos valores del dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Web (apps/web) ───────────────────────────────────────────────────────
# URL del backend que consume el storefront
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Videos en CDN (producción) ───────────────────────────────────────────
# Los .mp4 grandes NO van en git. Súbelos a Cloudinary y pega aquí las URLs.
# (NEXT_PUBLIC_* se hornea en build: en Render defínelas y RECONSTRUYE.)
NEXT_PUBLIC_IMMERSIVE_VIDEO_URL=
NEXT_PUBLIC_LOGO_VIDEO_URL=

# ─── Modo lanzamiento / coming soon ───────────────────────────────────────
# 'true' = solo hero + contador, sin scroll (tienda oculta). 'false' = tienda abierta.
NEXT_PUBLIC_LAUNCH_MODE=false
